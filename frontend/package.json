    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "codemirror": "^6.0.2",
    "croner": "10.0.1",
    "marked": "^18.0.6",
    "pinia": "^4.0.2",
    "prettier": "^3.9.5",
    "prismjs": "^1.30.0",
    "vue": "^3.5.40",
    "vue-draggable-plus": "^0.6.1",
