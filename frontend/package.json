    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.73.0",
    "eslint-plugin-vue": "^10.9.2",
    "less": "^4.6.7",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "~6.0.3",
